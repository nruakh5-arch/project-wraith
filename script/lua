-- ════════════════════════════════════════════
-- PAGE FACTORY
-- ════════════════════════════════════════════
local pages = {}

local function makePage(name)
    local sf = Instance.new("ScrollingFrame")
    sf.Name                  = name
    sf.Size                  = UDim2.new(1,0,1,0)
    sf.BackgroundTransparency = 1
    sf.BorderSizePixel       = 0
    sf.ScrollBarThickness    = 3
    sf.ScrollBarImageColor3  = C.accent
    sf.CanvasSize            = UDim2.new(0,0,0,0)
    pcall(function() sf.AutomaticCanvasSize = Enum.AutomaticSize.Y end)
    sf.Visible               = false
    sf.ZIndex                = 12
    sf.Parent                = contentArea

    local ul = Instance.new("UIListLayout")
    ul.Padding = UDim.new(0,8)
    ul.Parent  = sf

    local up = Instance.new("UIPadding")
    up.PaddingLeft=UDim.new(0,12); up.PaddingRight=UDim.new(0,12)
    up.PaddingTop=UDim.new(0,14);  up.PaddingBottom=UDim.new(0,16)
    up.Parent = sf

    pages[name] = sf
    return sf
end

