titleBar.InputBegan:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then
        dragging=true; dragOrig=i.Position; winOrig=win.Position
    end
end)
UserInputService.InputEnded:Connect(function(i)
    if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
end)
UserInputService.InputChanged:Connect(function(i)
    if dragging and i.UserInputType==Enum.UserInputType.MouseMovement then
        local d=i.Position-dragOrig
        win.Position=UDim2.new(winOrig.X.Scale,winOrig.X.Offset+d.X,winOrig.Y.Scale,winOrig.Y.Offset+d.Y)
    end
end)

-- ════════════════════════════════════════════
-- GLOBAL KEYBINDS
-- ════════════════════════════════════════════
UserInputService.InputBegan:Connect(function(input,gp)
    if gp then return end
    if input.KeyCode==S.guiKey then
        win.Visible=not win.Visible
        if win.Visible then win.Position=UDim2.new(0.5,-WIN_W/2,0.5,-WIN_H/2) end
    elseif input.KeyCode==S.toggleKey then
        S.enabled=not S.enabled
        notify("Leg Reach "..(S.enabled and "ON" or "OFF"), S.enabled and C.green or C.red)
    end
end)

