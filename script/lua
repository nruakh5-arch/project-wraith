local function spawnNotif(msg, col)
    col = col or C.accent
    local nf = Instance.new("Frame")
    nf.Size                   = UDim2.new(1,0,0,46)
    nf.BackgroundColor3       = C.bg1
    nf.BorderSizePixel        = 0
    nf.BackgroundTransparency = 1
    nf.ZIndex                 = 301
    nf.Parent                 = notifHolder
    Instance.new("UICorner",nf).CornerRadius = UDim.new(0,12)

    local stroke = Instance.new("UIStroke")
    stroke.Color       = col
    stroke.Thickness   = 1
    stroke.Transparency = 0.5
    stroke.Parent      = nf

    local bar = Instance.new("Frame")
    bar.Size             = UDim2.new(0,3,1,-14)
    bar.Position         = UDim2.new(0,7,0,7)
    bar.BackgroundColor3 = col
    bar.BorderSizePixel  = 0
    bar.ZIndex           = 302
    bar.Parent           = nf
    Instance.new("UICorner",bar).CornerRadius = UDim.new(1,0)

    -- sword icon
    local icon = Instance.new("TextLabel")
    icon.Size               = UDim2.new(0,18,0,18)
    icon.Position           = UDim2.new(0,16,0.5,-9)
    icon.BackgroundTransparency = 1
    icon.Text               = "⚔"
    icon.TextColor3         = col
    icon.TextSize           = 13
    icon.Font               = Enum.Font.GothamBold
    icon.ZIndex             = 302
    icon.Parent             = nf

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1,-44,1,0)
    lbl.Position           = UDim2.new(0,38,0,0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = msg
    lbl.TextColor3         = C.text0
    lbl.TextSize           = 12
    lbl.Font               = Enum.Font.GothamMedium
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 302
    lbl.Parent             = nf

    TweenService:Create(nf,TweenInfo.new(0.25,Enum.EasingStyle.Quart),{BackgroundTransparency=0}):Play()
    task.delay(2.6,function()
        TweenService:Create(nf,TweenInfo.new(0.3,Enum.EasingStyle.Quart),{BackgroundTransparency=1}):Play()
        task.wait(0.31); nf:Destroy()
    end)
end

notify = function(msg, col)
    spawnNotif(msg, col)
    logEvent(msg)
end

