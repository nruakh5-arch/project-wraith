-- ════════════════════════════════════════════
-- TAB SWITCHING
-- ════════════════════════════════════════════
local tabBtns={}; local activeTab="REACH"

local function switchTab(name)
    activeTab=name
    for tn,page in pairs(pages) do page.Visible=(tn==name) end
    for tn,btn in pairs(tabBtns) do
        local on=(tn==name)
        TweenService:Create(btn,TweenInfo.new(0.15),{
            TextColor3       = on and C.text0 or C.text2,
            BackgroundColor3 = on and Color3.fromRGB(18,22,45) or C.bg0,
        }):Play()
        -- active indicator line
        if btn:FindFirstChild("Indicator") then
            btn.Indicator.BackgroundTransparency = on and 0 or 1
        end
    end
end

local tabW = math.floor(WIN_W / #TAB_NAMES)
for _,tName in ipairs(TAB_NAMES) do
    local btn=Instance.new("TextButton")
    btn.Name=tName; btn.Size=UDim2.new(0,tabW,1,0)
    btn.BackgroundColor3=C.bg0; btn.Text=tName
    btn.TextColor3=C.text2; btn.TextSize=8
    btn.Font=Enum.Font.GothamBold; btn.BorderSizePixel=0
    btn.ZIndex=12; btn.Parent=tabBar
    tabBtns[tName]=btn

    -- active indicator bar at top
    local ind=Instance.new("Frame")
    ind.Name="Indicator"; ind.Size=UDim2.new(0.7,0,0,2)
    ind.Position=UDim2.new(0.15,0,0,0)
    ind.BackgroundColor3=C.accent; ind.BorderSizePixel=0
    ind.BackgroundTransparency=1; ind.ZIndex=13; ind.Parent=btn
    Instance.new("UICorner",ind).CornerRadius=UDim.new(1,0)

    btn.MouseButton1Click:Connect(function() switchTab(tName) end)
end
switchTab("REACH")

