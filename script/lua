-- ════════════════════════════════════════════
local LEG_NAMES={
    "LL","RL","Left Leg","Right Leg","Fake_LL","FakeRL",
    "LeftLowerLeg","LeftUpperLeg","RightLowerLeg","RightUpperLeg","LeftFoot","RightFoot"
}
local HEAD_NAMES={"Head","head"}
local legs={}; local heads={}

local function updateLimbs(char)
    table.clear(legs); table.clear(heads)
    for _,name in ipairs(LEG_NAMES) do
        local p=char:FindFirstChild(name,true)
        if p and p:IsA("BasePart") then table.insert(legs,p) end
    end
    for _,name in ipairs(HEAD_NAMES) do
        local p=char:FindFirstChild(name,true)
        if p and p:IsA("BasePart") then table.insert(heads,p) end
    end
    hitboxDirty = true
end
updateLimbs(character)
player.CharacterAdded:Connect(function(char)
    character=char; task.wait(1); updateLimbs(char)
    hitboxDirty = true
    for _,p in ipairs(hitboxParts) do p:Destroy() end; table.clear(hitboxParts)
end)

-- ════════════════════════════════════════════
-- BALL TRACKING
-- ════════════════════════════════════════════
local BALL_NAMES={
    TPS=true,Ball=true,Football=true,SAML=true,SSS=true,
    RSA=true,IFF=true,MPS=true,Bomb=true,bomb=true,
    VEF=true,VRF=true,CBM=true,RFF=true,TRS=true
}
local balls={}
local function trackBall(obj)
    if obj:IsA("BasePart") and BALL_NAMES[obj.Name] then
        table.insert(balls,obj)
        espDirty = true
    end
end
for _,obj in ipairs(WS:GetDescendants()) do trackBall(obj) end
WS.DescendantAdded:Connect(trackBall)
WS.DescendantRemoving:Connect(function(obj)
    for i=#balls,1,-1 do
        if balls[i]==obj then
            table.remove(balls,i)
            ballVelocities[obj]=nil; lastBallPositions[obj]=nil
            if ballSelBoxes[obj] then ballSelBoxes[obj]:Destroy(); ballSelBoxes[obj]=nil end
            espDirty = true
        end
    end
end)

-- ════════════════════════════════════════════
-- HITBOX VISUALIZER
-- ════════════════════════════════════════════
local function rebuildHitbox()
    -- Only rebuild when legs actually changed, not every frame
    if not hitboxDirty and #hitboxParts > 0 then return end
    hitboxDirty = false
    for _,p in ipairs(hitboxParts) do p:Destroy() end; table.clear(hitboxParts)
    if not S.showHitbox then return end
    for _,leg in ipairs(legs) do
        if leg and leg.Parent then
            local sb=Instance.new("SelectionBox")
            sb.Adornee=leg; sb.Color3=C.accent; sb.LineThickness=0.03
            sb.SurfaceTransparency=0.84; sb.SurfaceColor3=C.accent; sb.Parent=WS
            table.insert(hitboxParts,sb)
        end
    end
end

-- ════════════════════════════════════════════
-- BALL ESP
-- ════════════════════════════════════════════
local function updateBallESP()
    if not S.ballESP then return end
    -- Only do the full loop when balls list has changed
    if not espDirty then return end
    espDirty = false
    for _,ball in ipairs(balls) do
        if ball and ball.Parent and not ballSelBoxes[ball] then
            local sb=Instance.new("SelectionBox")
            sb.Adornee=ball; sb.Color3=C.gold; sb.LineThickness=0.07
            sb.SurfaceTransparency=0.7; sb.SurfaceColor3=C.gold; sb.Parent=WS
            ballSelBoxes[ball]=sb
        end
    end
    for ball,sb in pairs(ballSelBoxes) do
        if not ball or not ball.Parent then sb:Destroy(); ballSelBoxes[ball]=nil end
    end
end

-- ════════════════════════════════════════════
-- PLAYER HIGHLIGHT (uses Highlight instance)
-- ════════════════════════════════════════════
local function updatePlayerHighlights()
    if not S.playerHighlight then return end
    if not highlightDirty then return end
    highlightDirty = false
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player and p.Character then
            if not playerHighlights[p] then
                local ok_h, h = pcall(Instance.new, "Highlight")
                if ok_h and h then
                    h.FillTransparency=0.75; h.OutlineTransparency=0.1
                    pcall(function() h.DepthMode=Enum.HighlightDepthMode.Occluded end)
                    h.Parent=p.Character
                    playerHighlights[p]=h
                end
            end
            local col
            if player.Team and p.Team then
                col=p.Team==player.Team and S.teamColor or S.enemyColor
            else
                col=S.enemyColor
            end
            playerHighlights[p].FillColor=col
            playerHighlights[p].OutlineColor=col
        end
    end
    for p,h in pairs(playerHighlights) do
        if not p or not p.Parent or not p.Character then
            h:Destroy(); playerHighlights[p]=nil
        end
    end
end
Players.PlayerAdded:Connect(function() highlightDirty = true end)
Players.PlayerRemoving:Connect(function(p)
    highlightDirty = true
    if playerHighlights[p] then playerHighlights[p]:Destroy(); playerHighlights[p]=nil end
end)

-- ════════════════════════════════════════════
-- TRAJECTORY LINE
-- ════════════════════════════════════════════
local function clearTraj()
    for _,p in ipairs(trajParts) do p:Destroy() end; table.clear(trajParts)
end

local function updateTrajectory(ball)
    if not S.trajEnabled or not ball or not ball.Parent then clearTraj(); return end
    local vel=ballVelocities[ball]
    if not vel or vel.Magnitude<0.5 then clearTraj(); return end

    local segs=math.floor(S.trajSegments)
    local dt=0.06
    local grav=Vector3.new(0,-GRAVITY,0)
    local points={}
    local pos=ball.Position; local v=vel
    for i=1,segs+1 do
        table.insert(points,pos)
        v=v+grav*dt; pos=pos+v*dt
    end

    while #trajParts<segs do
        local p=Instance.new("Part")
        p.Anchored=true; p.CanCollide=false; p.CastShadow=false
        p.Material=Enum.Material.Neon; p.Size=Vector3.new(0.07,0.07,1)
        p.Color=S.trajColor; p.Parent=WS
        table.insert(trajParts,p)
    end
    while #trajParts>segs do trajParts[#trajParts]:Destroy(); table.remove(trajParts) end

    for i=1,segs do
        local a,b=points[i],points[i+1]
        local mid=(a+b)*0.5; local len=(b-a).Magnitude
        local fade=1-(i-1)/segs
        trajParts[i].CFrame=CFrame.new(mid,b)
        trajParts[i].Size=Vector3.new(0.05,0.05,len)
        trajParts[i].Color=S.trajColor
        trajParts[i].Transparency=lerp(0.1,0.94,1-fade)
    end
end

-- ════════════════════════════════════════════
-- GK PREDICTOR
-- ════════════════════════════════════════════
local function findGoalPos()
    local goalKeywords={"Goal","goal","Net","net","GoalPost","goalpost","Frame"}
    for _,obj in ipairs(WS:GetDescendants()) do
        if obj:IsA("BasePart") then
            for _,kw in ipairs(goalKeywords) do
                if obj.Name:find(kw) then return obj.Position end
            end
        end
    end
    return nil
end

local function updateGKPredictor(ball)
    if not S.gkPredictor or not ball or not ball.Parent then
        if gkMarker then gkMarker:Destroy(); gkMarker=nil end; return
    end
    local vel=ballVelocities[ball]
    if not vel or vel.Magnitude<1 then return end
    local goalPos=findGoalPos(); if not goalPos then return end
    local dt=0.05; local grav=Vector3.new(0,-GRAVITY,0)
    local pos=ball.Position; local v=vel; local landPos=nil
    for _=1,120 do
        v=v+grav*dt; pos=pos+v*dt
        if (pos-goalPos).Magnitude<6 then landPos=pos; break end
        if pos.Y<-10 then break end
    end
    if not landPos then
        if gkMarker then gkMarker:Destroy(); gkMarker=nil end; return
    end
    if not gkMarker then
        gkMarker=Instance.new("Part"); gkMarker.Anchored=true; gkMarker.CanCollide=false
        gkMarker.CastShadow=false; gkMarker.Material=Enum.Material.Neon
        gkMarker.Shape=Enum.PartType.Ball; gkMarker.Size=Vector3.new(0.65,0.65,0.65)
        gkMarker.Color=S.gkPredictColor; gkMarker.Transparency=0.15; gkMarker.Parent=WS
    end
    gkMarker.Position=landPos
end

-- ════════════════════════════════════════════
-- DESYNC
-- ════════════════════════════════════════════
local desyncConn=nil
local function tickDesync()
    if desyncConn then desyncConn:Disconnect(); desyncConn=nil end
    if not S.desyncEnabled then return end
    desyncConn=RunService.RenderStepped:Connect(function()
        if not S.desyncEnabled then return end
        local root=character and character:FindFirstChild("HumanoidRootPart")
        if not root then return end
        local str=S.desyncStrength
        local offset=Vector3.new((math.random()-0.5)*2*str,0,(math.random()-0.5)*2*str)
        root.CFrame=CFrame.new(root.Position+offset)*CFrame.Angles(root.CFrame:ToEulerAnglesXYZ())
    end)
end

-- ════════════════════════════════════════════
-- PASS PREDICTOR  (nearest enemy → nearest teammate of that enemy)
-- ════════════════════════════════════════════
local function updatePassPredictor()
    if not S.passPredictor then
        for _,p in ipairs(passParts) do p:Destroy() end; table.clear(passParts)
        return
    end
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    -- Find nearest enemy to us
    local nearestEnemy, nearestEnemyDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local isEnemy = true
            if player.Team and p.Team then isEnemy = p.Team ~= player.Team end
            if isEnemy then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r then
                    local d = (r.Position - root.Position).Magnitude
                    if d < nearestEnemyDist then
                        nearestEnemyDist = d
                        nearestEnemy = p
                    end
                end
            end
        end
    end
    if not nearestEnemy then
        for _,p in ipairs(passParts) do p:Destroy() end; table.clear(passParts)
        return
    end
    local eRoot = nearestEnemy.Character:FindFirstChild("HumanoidRootPart")
    if not eRoot then return end

    -- Find nearest teammate of that enemy (same team as enemy, not the enemy itself)
    local nearestAlly, nearestAllyDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p ~= nearestEnemy and p.Character then
            local sameTeamAsEnemy = false
            if nearestEnemy.Team and p.Team then
                sameTeamAsEnemy = p.Team == nearestEnemy.Team
            else
                -- no teams: treat everyone else as potential ally
                sameTeamAsEnemy = true
            end
            if sameTeamAsEnemy then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r then
                    local d = (r.Position - eRoot.Position).Magnitude
                    if d < nearestAllyDist then
                        nearestAllyDist = d
                        nearestAlly = p
                    end
                end
            end
        end
    end
    if not nearestAlly then
        for _,p in ipairs(passParts) do p:Destroy() end; table.clear(passParts)
        return
    end
    local aRoot = nearestAlly.Character:FindFirstChild("HumanoidRootPart")
    if not aRoot then return end

    -- Draw one line: enemy pos → ally pos
    local posA = eRoot.Position
    local posB = aRoot.Position
    local mid  = (posA + posB) * 0.5
    local len  = (posB - posA).Magnitude

    if #passParts < 1 then
        local p = Instance.new("Part")
        p.Anchored=true; p.CanCollide=false; p.CastShadow=false
        p.Material=Enum.Material.Neon; p.Size=Vector3.new(0.06,0.06,1)
        p.Color=C.purple; p.Transparency=0.25; p.Parent=WS
        table.insert(passParts,p)
    end
    while #passParts > 1 do passParts[#passParts]:Destroy(); table.remove(passParts) end

    passParts[1].CFrame = CFrame.new(mid, posB)
    passParts[1].Size   = Vector3.new(0.06,0.06,len)
end


-- ════════════════════════════════════════════
-- BALL ARROW  (edge-of-screen indicator)
-- ════════════════════════════════════════════
local function updateBallArrow()
    if not S.ballArrow or not ballArrowFrame then return end
    local ball = cachedClosestBall
    if not ball or not ball.Parent then
        ballArrowFrame.Visible = false; return
    end

    -- Project ball world pos to screen
    local screenPos, onScreen = camera:WorldToScreenPoint(ball.Position)

    if onScreen then
        -- Ball is visible — hide arrow
        ballArrowFrame.Visible = false
        return
    end

    ballArrowFrame.Visible = true
    local vp     = camera.ViewportSize
    local cx, cy = vp.X * 0.5, vp.Y * 0.5
    local margin = 40

    -- Direction from screen centre to projected ball position
    local dx = screenPos.X - cx
    local dy = screenPos.Y - cy
    local angle = math.atan2(dy, dx)

    -- Clamp to screen edge
    local absDx = math.abs(dx); local absDy = math.abs(dy)
    local scale  = math.min((cx - margin) / absDx, (cy - margin) / absDy)
    local ex     = cx + dx * scale
    local ey     = cy + dy * scale

    ballArrowFrame.Position = UDim2.new(0, ex, 0, ey)
    arrowTri.Rotation       = math.deg(angle) + 90  -- ▲ points in travel direction

    -- Distance label
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if root then
        local d = math.floor((ball.Position - root.Position).Magnitude)
        arrowLabel.Text = d .. "st"
    end
end

-- ════════════════════════════════════════════
-- MINI SCOREBOARD
-- ════════════════════════════════════════════
local function updateMiniScoreboard()
    if not S.miniScoreboard or not miniScoreFrame then return end
    local ball = cachedClosestBall
    if not ball or not ball.Parent then return end

    -- Build sorted list of all players by distance to ball
    local list = {}
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            if r then
                local d = math.floor((r.Position - ball.Position).Magnitude)
                table.insert(list, {name=p.Name, dist=d, isMe=(p==player), team=p.Team})
            end
        end
    end
    table.sort(list, function(a,b) return a.dist < b.dist end)

    -- Rebuild rows (max 8)
    for _, r in ipairs(msRows) do r:Destroy() end; table.clear(msRows)
    local count = math.min(#list, 8)
    for i = 1, count do
        local entry = list[i]
        local row   = Instance.new("TextLabel")
        row.Size    = UDim2.new(1,0,0,16); row.BackgroundTransparency=1
        local col   = entry.isMe and C.accent
                      or (player.Team and entry.team == player.Team and C.green or C.red)
        local prefix = i == 1 and "🏆 " or (i .. ". ")
        row.Text    = prefix .. entry.name .. "  " .. entry.dist .. "st"
        row.TextColor3 = col; row.TextSize=10; row.Font=Enum.Font.GothamMedium
        row.TextXAlignment=Enum.TextXAlignment.Left; row.ZIndex=62
        local pad=Instance.new("UIPadding"); pad.PaddingLeft=UDim.new(0,8); pad.Parent=row
        row.Parent  = msListFrame
        table.insert(msRows, row)
    end
end

-- ════════════════════════════════════════════
-- FINGERPRINT RANDOMISER
-- ════════════════════════════════════════════
local function tickFingerprintRandomiser(dt)
    if not S.fingerprintRandomiser then return end
    fingerprintTimer = fingerprintTimer + dt
    if fingerprintTimer >= 30 then
        fingerprintTimer = 0
        local r = S.fingerprintRange
        S.reachX = fpBaseX + (math.random() * 2 - 1) * r
        S.reachY = fpBaseY + (math.random() * 2 - 1) * r
        S.reachZ = fpBaseZ + (math.random() * 2 - 1) * r
        -- clamp to sane bounds
        S.reachX = math.clamp(S.reachX, 0.5, 20)
        S.reachY = math.clamp(S.reachY, 0.5, 20)
        S.reachZ = math.clamp(S.reachZ, 0.5, 20)
    end
end

-- ════════════════════════════════════════════
-- BALL TRAIL
-- ════════════════════════════════════════════
local function updateBallTrail()
    local ball = cachedClosestBall
    if not S.ballTrail then
        if ballTrailInst then ballTrailInst:Destroy(); ballTrailInst=nil end
        return
    end
    if not ball or not ball.Parent then
        if ballTrailInst then ballTrailInst:Destroy(); ballTrailInst=nil end
        return
    end
    -- Create trail attached to ball if not yet created
    if not ballTrailInst or not ballTrailInst.Parent then
        pcall(function()
            local att0 = ball:FindFirstChild("TrailAtt0") or Instance.new("Attachment")
            att0.Name="TrailAtt0"; att0.Position=Vector3.new(0,0.5,0); att0.Parent=ball
            local att1 = ball:FindFirstChild("TrailAtt1") or Instance.new("Attachment")
            att1.Name="TrailAtt1"; att1.Position=Vector3.new(0,-0.5,0); att1.Parent=ball
            local trail=Instance.new("Trail")
            trail.Attachment0=att0; trail.Attachment1=att1
            trail.Lifetime=0.5; trail.MinLength=0.02; trail.FaceCamera=true
            trail.Color=ColorSequence.new({
                ColorSequenceKeypoint.new(0,C.gold),
                ColorSequenceKeypoint.new(1,Color3.fromRGB(255,80,30)),
            })
            trail.Transparency=NumberSequence.new({
                NumberSequenceKeypoint.new(0,0.1),NumberSequenceKeypoint.new(1,1),
            })
            trail.Parent=ball; ballTrailInst=trail
        end)
    end
end

-- ════════════════════════════════════════════
-- VELOCITY VECTOR ARROW
-- ════════════════════════════════════════════
local function updateVelocityArrow()
    if not S.velocityArrow then
        if velArrowPart then velArrowPart:Destroy(); velArrowPart=nil end
        return
    end
    local ball = cachedClosestBall
    if not ball or not ball.Parent then
        if velArrowPart then velArrowPart:Destroy(); velArrowPart=nil end
        return
    end
    local vel = ballVelocities[ball]
    if not vel or vel.Magnitude < 0.5 then
        if velArrowPart then velArrowPart.Transparency=1 end
        return
    end
    if not velArrowPart or not velArrowPart.Parent then
        velArrowPart = Instance.new("Part")
        velArrowPart.Anchored=true; velArrowPart.CanCollide=false; velArrowPart.CastShadow=false
        velArrowPart.Material=Enum.Material.Neon; velArrowPart.Color=C.cyan
        velArrowPart.Parent=WS
    end
    local spd  = vel.Magnitude
    local len  = math.clamp(spd * 0.25, 0.5, 12)  -- scales with speed
    local mid  = ball.Position + vel.Unit * (len * 0.5)
    velArrowPart.Size       = Vector3.new(0.1, 0.1, len)
    velArrowPart.CFrame     = CFrame.new(mid, ball.Position + vel.Unit * len)
    velArrowPart.Transparency = 0.1
    -- Colour shifts: cyan = slow, gold = fast
    local t = math.clamp(spd / 60, 0, 1)
    velArrowPart.Color = Color3.fromRGB(
        math.floor(lerp(55, 255, t)),
        math.floor(lerp(210, 195, t)),
        math.floor(lerp(215, 55, t))
    )
end

-- ════════════════════════════════════════════
-- PLAYER PATH LINES
-- ════════════════════════════════════════════
local PATH_MAX_POS  = 20    -- store last 20 positions
local PATH_INTERVAL = 3     -- record position every N frames
local pathFrameCount = 0

local function updatePathLines(frameNum)
    pathFrameCount = pathFrameCount + 1
    -- record positions every PATH_INTERVAL frames
    local record = pathFrameCount % PATH_INTERVAL == 0

    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= player and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            if r then
                if not pathData[p] then
                    pathData[p] = {parts={}, positions={}}
                end
                local d = pathData[p]

                if record then
                    table.insert(d.positions, 1, r.Position)
                    if #d.positions > PATH_MAX_POS then table.remove(d.positions) end
                end

                if not S.pathLines then
                    for _,pt in ipairs(d.parts) do pt:Destroy() end
                    table.clear(d.parts); table.clear(d.positions)
                else
                    -- ensure enough parts
                    local needed = math.max(0, #d.positions - 1)
                    while #d.parts < needed do
                        local pt=Instance.new("Part")
                        pt.Anchored=true; pt.CanCollide=false; pt.CastShadow=false
                        pt.Material=Enum.Material.Neon
                        pt.Size=Vector3.new(0.06,0.06,1); pt.Parent=WS
                        table.insert(d.parts,pt)
                    end
                    while #d.parts > needed do
                        d.parts[#d.parts]:Destroy(); table.remove(d.parts)
                    end
                    -- determine colour
                    local col = C.red
                    if player.Team and p.Team then
                        col = p.Team == player.Team and C.green or C.red
                    end
                    -- position parts between consecutive recorded positions
                    for i = 1, needed do
                        local a = d.positions[i]
                        local b = d.positions[i+1]
                        local mid = (a+b)*0.5
                        local len = (b-a).Magnitude
                        local fade = 1 - (i-1)/(PATH_MAX_POS)
                        d.parts[i].CFrame = CFrame.new(mid,b)
                        d.parts[i].Size   = Vector3.new(0.05,0.05,math.max(len,0.05))
                        d.parts[i].Color  = col
                        d.parts[i].Transparency = lerp(0.1, 0.95, 1-fade)
                    end
                end
            end
        end
    end
    -- clean up players who left
    for p, d in pairs(pathData) do
        if not p or not p.Parent then
            for _,pt in ipairs(d.parts) do pt:Destroy() end
            pathData[p]=nil
        end
    end
end

-- ════════════════════════════════════════════
-- RAINBOW MODE
-- ════════════════════════════════════════════
local function tickRainbow(dt)
    if not S.rainbowMode then return end
    rainbowHue = (rainbowHue + dt * 0.08) % 1
    local newAccent = Color3.fromHSV(rainbowHue, 0.75, 1)
    C.accent = newAccent
    -- propagate to key UI elements
    if pingLbl         then pingLbl.TextColor3        = newAccent end
    if watermarkLabel  then watermarkLabel.TextColor3  = newAccent end
end

-- ════════════════════════════════════════════
-- SERVER INFO UPDATE
-- ════════════════════════════════════════════
local siUpdateTimer = 0
local function updateServerInfo(dt)
    if not S.serverInfoEnabled then return end
    siUpdateTimer = siUpdateTimer + dt
    if siUpdateTimer < 5 then return end  -- update every 5s
    siUpdateTimer = 0

    local jobId   = game.JobId ~= "" and game.JobId:sub(1,8).."…" or "Studio"
    local age     = math.floor(tick() - serverStartTick)
    local ageStr  = age >= 60 and (math.floor(age/60).."m "..(age%60).."s") or (age.."s")
    local ping    = 0
    pcall(function() ping=math.floor(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()) end)
    local region  = ping < 60 and "EU/NA close" or (ping < 120 and "EU/NA far" or "Asia/SA")

    siRows[1].Text = "Server ID:   " .. jobId
    siRows[2].Text = "Region:      " .. region .. " (~"..ping.."ms)"
    siRows[3].Text = "Players:     " .. #Players:GetPlayers()
    siRows[4].Text = "Server Age:  " .. ageStr
    siRows[5].Text = "Your ID:     " .. player.UserId
end

