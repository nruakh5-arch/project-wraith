-- ════════════════════════════════════════════
-- BALL LANDING ZONE
-- Flat cylinder on ground below ball, radius scales with height
-- ════════════════════════════════════════════
local function updateLandingZone()
    if not S.landingZone then
        if landingZonePart then landingZonePart.Transparency=1 end
        return
    end
    local ball = cachedClosestBall
    if not ball or not ball.Parent then
        if landingZonePart then landingZonePart.Transparency=1 end
        return
    end

    -- Create part once
    if not landingZonePart or not landingZonePart.Parent then
        landingZonePart = Instance.new("Part")
        landingZonePart.Anchored    = true
        landingZonePart.CanCollide  = false
        landingZonePart.CastShadow  = false
        landingZonePart.Material    = Enum.Material.Neon
        landingZonePart.Shape       = Enum.PartType.Cylinder
        landingZonePart.Color       = C.cyan
        landingZonePart.Parent      = WS
    end

    local ballPos  = ball.Position
    -- Height above ground: raycast straight down
    local rayDir   = Vector3.new(0, -200, 0)
    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {character, ball}
    rayParams.FilterType = Enum.RaycastFilterType.Exclude
    local hit = WS:Raycast(ballPos, rayDir, rayParams)
    local groundY = hit and hit.Position.Y or (ballPos.Y - ballPos.Y % 1)
    local height  = math.max(0, ballPos.Y - groundY)

    -- Radius grows with height, min 1.5, max 8
    local radius  = math.clamp(1.5 + height * 0.18, 1.5, 8)
    -- Fade out when ball is nearly on ground
    local alpha   = math.clamp(height / 3, 0, 1)

    landingZonePart.Size        = Vector3.new(0.15, radius * 2, radius * 2)
    landingZonePart.CFrame      = CFrame.new(ballPos.X, groundY + 0.08, ballPos.Z)
                                  * CFrame.Angles(0, 0, math.pi/2)
    landingZonePart.Transparency = lerp(0.9, 0.25, alpha)
    landingZonePart.Color       = height > 6 and C.red or (height > 2 and C.gold or C.green)
end

-- ════════════════════════════════════════════
-- LAST SEEN GHOST
-- Leaves a faded BillboardGui marker at enemy's last known position
-- ════════════════════════════════════════════
local lastSeenCheckTimer = 0

local function updateLastSeenGhost(dt)
    local now = tick()

    -- Expire old ghosts
    for p, d in pairs(lastSeenData) do
        if now >= d.expiry then
            if d.part then d.part:Destroy() end
            lastSeenData[p] = nil
        end
    end

    if not S.lastSeenGhost then
        for _, d in pairs(lastSeenData) do if d.part then d.part:Destroy() end end
        table.clear(lastSeenData)
        return
    end

    lastSeenCheckTimer = lastSeenCheckTimer + dt
    if lastSeenCheckTimer < 0.1 then return end
    lastSeenCheckTimer = 0

    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        -- Only track enemies
        local isEnemy = true
        if player.Team and p.Team then isEnemy = p.Team ~= player.Team end
        if not isEnemy then continue end

        local pChar = p.Character
        local pRoot = pChar and pChar:FindFirstChild("HumanoidRootPart")
        if not pRoot then continue end

        -- Check if visible on screen
        local screenPos, onScreen = camera:WorldToScreenPoint(pRoot.Position)
        if onScreen and screenPos.Z > 0 then
            -- Player is visible — remove their ghost if it exists
            if lastSeenData[p] and lastSeenData[p].part then
                lastSeenData[p].part:Destroy()
                lastSeenData[p] = nil
            end
            -- Update their last known position (but no ghost while visible)
            lastSeenData[p] = lastSeenData[p] or {}
            lastSeenData[p].lastPos = pRoot.Position
            lastSeenData[p].expiry  = now + 999  -- no expiry while visible
            lastSeenData[p].visible = true
        else
            -- Player went off screen — spawn/update ghost
            local d = lastSeenData[p]
            if d and d.visible and d.lastPos then
                -- Just went off screen — create ghost marker
                d.visible = false
                d.expiry  = now + S.lastSeenDuration

                if d.part then d.part:Destroy() end

                local ghost = Instance.new("Part")
                ghost.Anchored   = true
                ghost.CanCollide = false
                ghost.CastShadow = false
                ghost.Size       = Vector3.new(1, 2, 1)
                ghost.Material   = Enum.Material.Neon
                ghost.Color      = C.red
                ghost.Transparency = 0.55
                ghost.CFrame     = CFrame.new(d.lastPos)
                ghost.Parent     = WS
                pcall(function()
                    Instance.new("UICorner")  -- not valid on Part but harmless
                end)

                -- Add a BillboardGui label
                local bb = Instance.new("BillboardGui")
                bb.Size          = UDim2.new(0, 60, 0, 20)
                bb.StudsOffset   = Vector3.new(0, 1.5, 0)
                bb.AlwaysOnTop   = true
                bb.Parent        = ghost
                local lbl = Instance.new("TextLabel")
                lbl.Size               = UDim2.new(1,0,1,0)
                lbl.BackgroundTransparency = 1
                lbl.Text               = p.Name
                lbl.TextColor3         = C.red
                lbl.TextSize           = 10
                lbl.Font               = Enum.Font.GothamBold
                lbl.Parent             = bb

                d.part = ghost

                -- Fade ghost out over its lifetime using a tween
                local lifetime = S.lastSeenDuration
                pcall(function()
                    TweenService:Create(ghost,
                        TweenInfo.new(lifetime, Enum.EasingStyle.Linear),
                        {Transparency = 1}
                    ):Play()
                end)
            end
        end
    end
end

-- ════════════════════════════════════════════
-- BALL VELOCITY COLOUR CODING
-- Updates SelectionBox colour based on ball speed
-- ════════════════════════════════════════════
local function updateBallVelColor()
    if not S.ballESP then return end
    local ball = cachedClosestBall
    if not ball or not ball.Parent then return end
    local sb = ballSelBoxes[ball]
    if not sb then return end

    local vel = ballVelocities[ball]
    local spd = vel and vel.Magnitude or 0

    local col
    if spd < 8 then
        col = C.green                              -- slow / stationary
    elseif spd < 28 then
        -- lerp green→gold
        local t = (spd - 8) / 20
        col = Color3.fromRGB(
            math.floor(lerp(60,  255, t)),
            math.floor(lerp(210, 195, t)),
            math.floor(lerp(110,  55, t)))
    else
        -- lerp gold→red
        local t = math.clamp((spd - 28) / 20, 0, 1)
        col = Color3.fromRGB(
            math.floor(lerp(255, 230, t)),
            math.floor(lerp(195,  65, t)),
            math.floor(lerp( 55,  65, t)))
    end

    sb.Color3        = col
    sb.SurfaceColor3 = col
end

-- ════════════════════════════════════════════
-- DANGER ZONE HIGHLIGHT
-- Cylinder ring on ground around player when enemy is closing
-- ════════════════════════════════════════════
local function updateDangerZone()
    if not S.dangerZone then
        if dangerZonePart then dangerZonePart.Transparency=1 end
        return
    end
    local root = character and character:FindFirstChild("HumanoidRootPart")
    if not root then
        if dangerZonePart then dangerZonePart.Transparency=1 end
        return
    end

    -- Create ring part once
    if not dangerZonePart or not dangerZonePart.Parent then
        dangerZonePart = Instance.new("Part")
        dangerZonePart.Anchored   = true
        dangerZonePart.CanCollide = false
        dangerZonePart.CastShadow = false
        dangerZonePart.Material   = Enum.Material.Neon
        dangerZonePart.Shape      = Enum.PartType.Cylinder
        dangerZonePart.Color      = C.red
        dangerZonePart.Parent     = WS
    end

    -- Check if any enemy is within danger radius and closing (moving toward us)
    local myPos    = root.Position
    local danger   = false
    local closest  = math.huge

    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        local isEnemy = true
        if player.Team and p.Team then isEnemy = p.Team ~= player.Team end
        if not isEnemy then continue end
        local pRoot = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
        if not pRoot then continue end
        local dist = (pRoot.Position - myPos).Magnitude
        if dist <= S.dangerRadius then
            -- Check if they're closing (velocity toward us)
            local vel = playerVelocities[p]
            local closing = false
            if vel then
                local toUs = (myPos - pRoot.Position)
                if toUs.Magnitude > 0 then
                    closing = vel:Dot(toUs.Unit) > 1.5
                end
            else
                closing = true  -- no velocity data, assume closing
            end
            if closing then
                danger = true
                if dist < closest then closest = dist end
            end
        end
    end

    local r = S.dangerRadius
    dangerZonePart.Size        = Vector3.new(0.15, r * 2, r * 2)
    dangerZonePart.CFrame      = CFrame.new(myPos.X, myPos.Y - 2.8, myPos.Z)
                                 * CFrame.Angles(0, 0, math.pi/2)

    if danger then
        -- Pulse opacity
        local pulse = 0.3 + 0.4 * math.abs(math.sin(tick() * 4))
        dangerZonePart.Transparency = pulse
        dangerZonePart.Color        = C.red
    else
        dangerZonePart.Transparency = 1  -- hidden when safe
    end
end

-- ════════════════════════════════════════════
-- BALL MAGNET INDICATOR
-- Pulses the ball arrow when ball is within reach range
-- ════════════════════════════════════════════
local function updateMagnetIndicator(dt)
    if not S.magnetIndicator or not ballArrowFrame or not S.ballArrow then return end

    local ball = cachedClosestBall
    if not ball or not ball.Parent then return end

    -- Check if ball overlaps with ANY leg reach box
    local inRange = false
    for _, leg in ipairs(legs) do
        if leg and leg.Parent then
            local delta = ball.Position - leg.Position
            if math.abs(delta.X) <= S.reachX
            and math.abs(delta.Y) <= S.reachY
            and math.abs(delta.Z) <= S.reachZ then
                inRange = true
                break
            end
        end
    end

    if inRange then
        magnetPulseTimer = magnetPulseTimer + dt
        -- Pulse every 0.18s
        if magnetPulseTimer >= 0.18 then
            magnetPulseTimer = 0
            magnetPulseState = not magnetPulseState
        end
        -- Alternate colour and size
        arrowTri.TextColor3  = magnetPulseState and C.green or Color3.fromRGB(255,255,255)
        arrowTri.TextSize    = magnetPulseState and 34 or 24
        arrowLabel.Text      = "IN RANGE"
        arrowLabel.TextColor3 = C.green
    else
        magnetPulseTimer = 0
        magnetPulseState = false
        arrowTri.TextColor3  = C.gold
        arrowTri.TextSize    = 28
        arrowLabel.TextColor3 = C.gold
        -- restore distance text (updateBallArrow handles this but reset label here)
    end
end

-- ════════════════════════════════════════════
-- ADMIN WATCHER
-- ════════════════════════════════════════════
Players.PlayerAdded:Connect(function(p)
    if S.autoDisableAdmin and isAdmin(p) then
        S.enabled=false; notify("Admin detected — reach off", C.gold)
    end
end)

-- ════════════════════════════════════════════
-- DIRECTIONAL / HELPERS
-- ════════════════════════════════════════════
local function isFacingBall(part,ballPos)
    if not S.directional then return true end
    local root=character and character:FindFirstChild("HumanoidRootPart")
    if not root then return true end
    return root.CFrame.LookVector:Dot((ballPos-root.Position).Unit) >= math.cos(math.rad(S.dirAngle/2))
end

local function getClosestBall()
    local closest,best=nil,math.huge
    local root=character and character:FindFirstChild("HumanoidRootPart"); if not root then return nil end
    for _,ball in ipairs(balls) do
        if ball and ball.Parent then
            local d=(ball.Position-root.Position).Magnitude; if d<best then best=d; closest=ball end
        end
    end
    return closest
end

local function ballOwnedByWhitelisted(ball)
    if not S.whitelistMode then return true end
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=player then
            for _,wn in ipairs(S.whitelist) do
                if p.Name==wn and p.Character then
                    local r=p.Character:FindFirstChild("HumanoidRootPart")
                    if r and (r.Position-ball.Position).Magnitude<10 then return true end
                end
            end
        end
    end
    return false
end

-- ════════════════════════════════════════════
-- MERGED HEARTBEAT  (single connection)
-- ════════════════════════════════════════════
local frameCount   = 0
local fpsTimer     = tick()
local fpsDisplay   = 0
local pingTimer    = 0

RunService.Heartbeat:Connect(function(dt)
    frameCount = frameCount + 1
    local now  = tick()
    local th   = S.visualThrottle   -- 1 = normal, 2 = perf mode

    -- FPS counter
    if now - fpsTimer >= 1 then
        fpsDisplay = frameCount; frameCount = 0; fpsTimer = now
    end

    -- ── PING (every ~1s) ────────────────────
    pingTimer = pingTimer + dt
    if pingTimer >= 1 then
        pingTimer = 0
        pcall(function()
            local ping = game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue()
            local ms   = math.floor(ping)
            local col  = ms < 80 and C.green or (ms < 150 and C.gold or C.red)
            pingLbl.Text       = ms .. " ms"
            pingLbl.TextColor3 = col
        end)
    end

    -- ── BURST LIMITER RESET (per second) ────
    if S.burstLimiter then
        S.burstTimer = S.burstTimer + dt
        if S.burstTimer >= 1 then
            S.burstTimer = 0
            S.burstCount = 0
        end
    end

    -- ── BALL VELOCITY TRACKING ──────────────
    if not S.perfMode or frameCount % 2 == 0 then
        for _, ball in ipairs(balls) do
            if ball and ball.Parent then
                local prev = lastBallPositions[ball]
                if prev then
                    ballVelocities[ball] = (ball.Position - prev) / math.max(dt, 0.001)
                end
                lastBallPositions[ball] = ball.Position
            end
        end
    end

    -- ── PLAYER VELOCITY TRACKING ────────────
    if frameCount % 2 == 0 then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Character then
                local r = p.Character:FindFirstChild("HumanoidRootPart")
                if r then
                    local prev = playerPrevPos[p]
                    if prev then
                        playerVelocities[p] = (r.Position - prev) / math.max(dt * 2, 0.001)
                    end
                    playerPrevPos[p] = r.Position
                end
            end
        end
    end

    -- ── CACHED CLOSEST BALL ─────────────────
    closestBallTimer = closestBallTimer + 1
    if closestBallTimer >= 6 * th then
        closestBallTimer = 0
        cachedClosestBall = getClosestBall()
    end

    -- ── STANDARD VISUALS (every 4*th frames) ─
    if frameCount % (4 * th) == 0 then
        if S.showHitbox      then rebuildHitbox()          end
        if S.ballESP         then updateBallESP()          end
        if S.playerHighlight then updatePlayerHighlights() end
        updateBallTrail()
        updateVelocityArrow()
        if S.ballVelColor    then updateBallVelColor()     end
    end

    -- ── AWARENESS VISUALS (every 3*th frames) ─
    if frameCount % (3 * th) == 0 then
        updateBallArrow()
        if S.passPredictor  then updatePassPredictor()  end
        if S.miniScoreboard then updateMiniScoreboard() end
        updateLandingZone()
        updateDangerZone()
    end

    -- ── LAST SEEN GHOST (every frame, dt-gated internally) ──
    updateLastSeenGhost(dt)

    -- ── MAGNET INDICATOR ────────────────────
    if S.magnetIndicator then updateMagnetIndicator(dt) end

    -- ── PLAYER PATH LINES ───────────────────
    if S.pathLines or next(pathData) ~= nil then
        updatePathLines(frameCount)
    end

    -- ── RAINBOW MODE ────────────────────────
    tickRainbow(dt)

    -- ── SERVER INFO ─────────────────────────
    if S.serverInfoEnabled then updateServerInfo(dt) end

    -- ── CLOCK (every 30 frames) ─────────────
    if frameCount % 30 == 0 and S.clockEnabled then
        local ok, t = pcall(os.date, "*t")
        if ok and type(t) == "table" then
            clockTimeLbl.Text = string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
        end
        clockSessionLbl.Text = "session " .. math.floor(now - S.sessionStart) .. "s"
    end

    -- ── FINGERPRINT RANDOMISER ───────────────
    tickFingerprintRandomiser(dt)

    -- ── TIME / AMBIENT ──────────────────────
    if S.timeEnabled    then Lighting.ClockTime = S.timeOfDay end
    if S.ambientEnabled then
        local b = math.min(255, math.floor(255 * (S.ambientBrightness - 1) / 4))
        Lighting.Ambient        = Color3.fromRGB(b, b, b)
        Lighting.OutdoorAmbient = Color3.fromRGB(b, b, b)
    end

    -- ── DESYNC ──────────────────────────────
    if S.desyncEnabled and not desyncConn then
        tickDesync()
    elseif not S.desyncEnabled and desyncConn then
        desyncConn:Disconnect(); desyncConn = nil
    end

    -- ── TRAJECTORY ──────────────────────────
    if S.trajEnabled and not S.disableTrajPerf then
        if frameCount % (2 * th) == 0 then
            local tb = S.closestOnly and cachedClosestBall
                       or (balls[1] and balls[1].Parent and balls[1])
            updateTrajectory(tb)
        end
    elseif #trajParts > 0 then
        clearTraj()
    end

    -- ── GK PREDICTOR ────────────────────────
    if S.gkPredictor and not S.disableGKPerf then
        if frameCount % (4 * th) == 0 then
            local tb = S.closestOnly and cachedClosestBall
                       or (balls[1] and balls[1].Parent and balls[1])
            updateGKPredictor(tb)
        end
    end

    -- ── STATUS BAR (every 16*th frames) ─────
    if frameCount % (16 * th) == 0 then
        local root = character and character:FindFirstChild("HumanoidRootPart")
        local nd   = "–"
        if root and #balls > 0 then
            local md = math.huge
            for _, b in ipairs(balls) do
                if b and b.Parent then
                    local d = (b.Position - root.Position).Magnitude
                    if d < md then md = d end
                end
            end
            if md < math.huge then nd = math.floor(md * 10 + 0.5) / 10 end
        end
        local modeTag = S.perfMode and "  [PERF]" or ""
        statusTxt.Text       = (S.enabled and "● ACTIVE" or "○ IDLE")
                               .. "  Ball: " .. nd .. "st  " .. fpsDisplay .. "fps" .. modeTag
        statusTxt.TextColor3 = S.enabled and C.green or C.text2
        touchTxt.Text        = "Touches: " .. S.touchCount
                               .. "   " .. math.floor(now - S.sessionStart) .. "s"
        refreshLog()
    end

    -- ══════════════════════════════════════
    -- REACH LOGIC
    -- ══════════════════════════════════════
    if #legs == 0 and #heads == 0 then return end

    -- Auto-reach trigger
    if S.autoReach and not S.enabled then
        local root2 = character and character:FindFirstChild("HumanoidRootPart")
        if root2 then
            for _, ball in ipairs(balls) do
                if ball and ball.Parent
                   and (ball.Position - root2.Position).Magnitude <= S.autoReachDist then
                    S.enabled = true; notify("Auto-reach on", C.cyan); break
                end
            end
        end
    end

    if not S.enabled then return end
    if S.cooldownEnabled and (now - lastTouchTime < S.cooldownTime) then return end
    if S.burstLimiter and S.burstCount >= S.burstMax then return end

    local ballList = S.closestOnly
        and (cachedClosestBall and {cachedClosestBall} or {})
        or balls

    -- Momentum offset
    local selfVelOffset = Vector3.new(0, 0, 0)
    if S.momentumPredict then
        local myVel = playerVelocities[player]
        if myVel then selfVelOffset = myVel * (3 / 60) end
    end

    for _, ball in ipairs(ballList) do
        if not ball or not ball.Parent then continue end
        if not ballOwnedByWhitelisted(ball) then continue end

        local checkPos = ball.Position
        if S.ballPredict then
            local vel = ballVelocities[ball]
            if vel then checkPos = checkPos + vel * (S.predictFrames / 60) end
        end

        -- ── LEG REACH ──
        for _, leg in ipairs(legs) do
            if not leg or not leg.Parent then continue end
            if not isFacingBall(leg, checkPos) then continue end
            if S.burstLimiter and S.burstCount >= S.burstMax then break end
            local rx = S.reachX + randomOffset()
            local ry = S.reachY + randomOffset()
            local rz = S.reachZ + randomOffset()
            if S.velocityReach then
                local vel = ballVelocities[ball]
                if vel then
                    local m = 1 + (vel.Magnitude / 20) * (S.velocityMult - 1)
                    rx = rx * m; ry = ry * m; rz = rz * m
                end
            end
            local legPos = leg.Position + selfVelOffset
            local delta  = checkPos - legPos
            if math.abs(delta.X) <= rx and math.abs(delta.Y) <= ry and math.abs(delta.Z) <= rz then
                firetouchinterest(ball, leg, 0)
                firetouchinterest(ball, leg, 1)
                lastTouchTime = tick()
                if S.trackStats then S.touchCount = S.touchCount + 1 end
                if S.burstLimiter then S.burstCount = S.burstCount + 1 end
            end
        end

        -- ── HEAD REACH ──
        if S.headReachEnabled then
            for _, head in ipairs(heads) do
                if not head or not head.Parent then continue end
                if S.burstLimiter and S.burstCount >= S.burstMax then break end
                local headPos = head.Position + selfVelOffset
                local delta   = checkPos - headPos
                local rx = S.headReachX + randomOffset()
                local ry = S.headReachY + randomOffset()
                local rz = S.headReachZ + randomOffset()
                if math.abs(delta.X) <= rx and math.abs(delta.Y) <= ry and math.abs(delta.Z) <= rz then
                    firetouchinterest(ball, head, 0)
                    firetouchinterest(ball, head, 1)
                    lastTouchTime = tick()
                    if S.trackStats then S.touchCount = S.touchCount + 1 end
                    if S.burstLimiter then S.burstCount = S.burstCount + 1 end
                end
            end
        end
    end
end)
-- ════════════════════════════════════════════
-- STARTUP
-- ════════════════════════════════════════════
-- (notifications fired after password unlock above)
