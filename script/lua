local function mkSection(page, title, icon)
    local row = Instance.new("Frame")
    row.Size                  = UDim2.new(1,0,0,28)
    row.BackgroundTransparency = 1
    row.ZIndex                = 13
    row.Parent                = page

    local line = Instance.new("Frame")
    line.Size             = UDim2.new(1,0,0,1)
    line.Position         = UDim2.new(0,0,0.5,0)
    line.BackgroundColor3 = C.border
    line.BorderSizePixel  = 0
    line.ZIndex           = 13
    line.Parent           = row

    local pill = Instance.new("Frame")
    pcall(function() pill.AutomaticSize = Enum.AutomaticSize.X end)
    pill.Size              = UDim2.new(0,0,0,22)
    pill.Position          = UDim2.new(0,0,0.5,-11)
    pill.BackgroundColor3  = C.bg1
    pill.BorderSizePixel   = 0
    pill.ZIndex            = 14
    pill.Parent            = row
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)
    local pp = Instance.new("UIPadding")
    pp.PaddingLeft=UDim.new(0,8); pp.PaddingRight=UDim.new(0,8); pp.Parent=pill

    local lbl = Instance.new("TextLabel")
    pcall(function() lbl.AutomaticSize = Enum.AutomaticSize.X end)
    lbl.Size               = UDim2.new(0,0,1,0)
    lbl.BackgroundTransparency = 1
    lbl.Text               = (icon or "◈") .. "  " .. title
    lbl.TextColor3         = C.accent
    lbl.TextSize           = 10
    lbl.Font               = Enum.Font.GothamBold
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 15
    lbl.Parent             = pill
end

local function mkSpacer(page, h)
    local s=Instance.new("Frame")
    s.Size=UDim2.new(1,0,0,h or 4)
    s.BackgroundTransparency=1; s.ZIndex=13; s.Parent=page
end

local function mkCard(page, h)
    local c = Instance.new("Frame")
    c.Size             = UDim2.new(1,0,0,h)
    c.BackgroundColor3 = C.bg2
    c.BorderSizePixel  = 0
    c.ZIndex           = 13
    c.Parent           = page
    Instance.new("UICorner",c).CornerRadius=UDim.new(0,12)
    local st=Instance.new("UIStroke")
    st.Color=C.border; st.Thickness=1; st.Parent=c
    return c
end

-- Toggle widget — returns (card, getState)
local function mkToggle(page, label, desc, default, callback)
    local h = desc and 58 or 46
    local card = mkCard(page, h)

    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1,-68,0,20)
    lbl.Position           = UDim2.new(0,14,0,desc and 10 or 13)
    lbl.BackgroundTransparency = 1
    lbl.Text               = label
    lbl.TextColor3         = C.text0
    lbl.TextSize           = 13
    lbl.Font               = Enum.Font.GothamSemibold
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.ZIndex             = 14
    lbl.Parent             = card

    if desc then
        local sub=Instance.new("TextLabel")
        sub.Size=UDim2.new(1,-68,0,14); sub.Position=UDim2.new(0,14,0,32)
        sub.BackgroundTransparency=1; sub.Text=desc
        sub.TextColor3=C.text2; sub.TextSize=10; sub.Font=Enum.Font.Gotham
        sub.TextXAlignment=Enum.TextXAlignment.Left; sub.ZIndex=14; sub.Parent=card
    end

    local pill=Instance.new("Frame")
    pill.Size=UDim2.new(0,44,0,24); pill.Position=UDim2.new(1,-56,0.5,-12)
    pill.BackgroundColor3=default and C.accent or C.bg3
    pill.BorderSizePixel=0; pill.ZIndex=14; pill.Parent=card
    Instance.new("UICorner",pill).CornerRadius=UDim.new(1,0)

    local knob=Instance.new("Frame")
    knob.Size=UDim2.new(0,18,0,18)
    knob.Position=default and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)
    knob.BackgroundColor3=Color3.fromRGB(255,255,255)
    knob.BorderSizePixel=0; knob.ZIndex=15; knob.Parent=pill
    Instance.new("UICorner",knob).CornerRadius=UDim.new(1,0)
    -- subtle shadow on knob
    local ks=Instance.new("UIStroke")
    ks.Color=Color3.fromRGB(0,0,0); ks.Transparency=0.7; ks.Thickness=1; ks.Parent=knob

    local state=default
    local hit=Instance.new("TextButton")
    hit.Size=UDim2.new(1,0,1,0); hit.BackgroundTransparency=1
    hit.Text=""; hit.ZIndex=16; hit.Parent=card

    hit.MouseButton1Click:Connect(function()
        state = not state
        local ti=TweenInfo.new(0.2,Enum.EasingStyle.Quart)
        TweenService:Create(pill,ti,{BackgroundColor3=state and C.accent or C.bg3}):Play()
        TweenService:Create(knob,ti,{
            Position=state and UDim2.new(1,-21,0.5,-9) or UDim2.new(0,3,0.5,-9)
        }):Play()
        if callback then callback(state) end
    end)

    return card, function() return state end
end

-- Slider widget
local function mkSlider(page, label, min, max, default, step, callback)
    step = step or 0.1
    local card = mkCard(page, 66)

    local lbl=Instance.new("TextLabel")
    lbl.Size=UDim2.new(0.62,0,0,18); lbl.Position=UDim2.new(0,14,0,10)
    lbl.BackgroundTransparency=1; lbl.Text=label
    lbl.TextColor3=C.text1; lbl.TextSize=12; lbl.Font=Enum.Font.GothamSemibold
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=14; lbl.Parent=card

    local valLbl=Instance.new("TextLabel")
    valLbl.Size=UDim2.new(0.35,0,0,18); valLbl.Position=UDim2.new(0.63,0,0,10)
    valLbl.BackgroundTransparency=1; valLbl.Text=tostring(default)
    valLbl.TextColor3=C.accent; valLbl.TextSize=12; valLbl.Font=Enum.Font.GothamBold
    valLbl.TextXAlignment=Enum.TextXAlignment.Right; valLbl.ZIndex=14; valLbl.Parent=card

    local track=Instance.new("Frame")
    track.Size=UDim2.new(1,-28,0,5); track.Position=UDim2.new(0,14,0,42)
    track.BackgroundColor3=C.bg3; track.BorderSizePixel=0; track.ZIndex=14; track.Parent=card
    Instance.new("UICorner",track).CornerRadius=UDim.new(1,0)

    local fill=Instance.new("Frame")
    local p0=(default-min)/(max-min)
    fill.Size=UDim2.new(p0,0,1,0); fill.BackgroundColor3=C.accent
    fill.BorderSizePixel=0; fill.ZIndex=15; fill.Parent=track
    Instance.new("UICorner",fill).CornerRadius=UDim.new(1,0)
    local fGrad=Instance.new("UIGradient")
    fGrad.Color=ColorSequence.new({
        ColorSequenceKeypoint.new(0,Color3.fromRGB(99,155,255)),
        ColorSequenceKeypoint.new(1,Color3.fromRGB(130,80,255)),
    })
    fGrad.Parent=fill

    local thumb=Instance.new("Frame")
    thumb.Size=UDim2.new(0,14,0,14); thumb.AnchorPoint=Vector2.new(0.5,0.5)
    thumb.Position=UDim2.new(p0,0,0.5,0); thumb.BackgroundColor3=Color3.fromRGB(240,240,255)
    thumb.BorderSizePixel=0; thumb.ZIndex=16; thumb.Parent=track
    Instance.new("UICorner",thumb).CornerRadius=UDim.new(1,0)

    local drag=false
    local function setVal(sx)
        local tx=track.AbsolutePosition.X; local tw=track.AbsoluteSize.X
        local rel=math.clamp((sx-tx)/tw,0,1)
        local raw=min+(max-min)*rel
        local snapped=math.floor(raw/step+0.5)*step
        snapped=math.clamp(math.floor(snapped*100+0.5)/100,min,max)
        local p=(snapped-min)/(max-min)
        fill.Size=UDim2.new(p,0,1,0); thumb.Position=UDim2.new(p,0,0.5,0)
        valLbl.Text=tostring(snapped)
        if callback then callback(snapped) end
    end

    thumb.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    track.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true; setVal(i.Position.X) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end end)
    UserInputService.InputChanged:Connect(function(i) if drag and i.UserInputType==Enum.UserInputType.MouseMovement then setVal(i.Position.X) end end)

    return card
end

-- Keybind
local function mkKeybind(page, label, keyRef, callback)
    local card=mkCard(page,46)
    local lbl=Instance.new("TextLabel")
    lbl.Size=UDim2.new(0.5,0,1,0); lbl.Position=UDim2.new(0,14,0,0)
    lbl.BackgroundTransparency=1; lbl.Text=label
    lbl.TextColor3=C.text1; lbl.TextSize=13; lbl.Font=Enum.Font.GothamSemibold
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.ZIndex=14; lbl.Parent=card

    local kb=Instance.new("TextButton")
    kb.Size=UDim2.new(0,120,0,28); kb.Position=UDim2.new(1,-128,0.5,-14)
    kb.BackgroundColor3=C.bg3; kb.Text=keyRef[1].Name
    kb.TextColor3=C.accent; kb.TextSize=11; kb.Font=Enum.Font.GothamBold
    kb.BorderSizePixel=0; kb.ZIndex=14; kb.Parent=card
    Instance.new("UICorner",kb).CornerRadius=UDim.new(0,8)
    local ks=Instance.new("UIStroke"); ks.Color=C.border; ks.Thickness=1; ks.Parent=kb

    local listening=false
    kb.MouseButton1Click:Connect(function()
        listening=true; kb.Text="PRESS KEY…"; kb.TextColor3=C.gold
    end)
    UserInputService.InputBegan:Connect(function(input,gp)
        if listening and not gp and input.KeyCode~=Enum.KeyCode.Unknown then
            listening=false; keyRef[1]=input.KeyCode
            kb.Text=input.KeyCode.Name; kb.TextColor3=C.accent
            if callback then callback(input.KeyCode) end
        end
    end)
    return card
end

-- Profile button
local function mkProfileBtn(page, name, callback)
    local card=mkCard(page,46)
    local nl=Instance.new("TextLabel")
    nl.Size=UDim2.new(0.55,0,1,0); nl.Position=UDim2.new(0,14,0,0)
    nl.BackgroundTransparency=1; nl.Text=name
    nl.TextColor3=C.text1; nl.TextSize=13; nl.Font=Enum.Font.GothamSemibold
    nl.TextXAlignment=Enum.TextXAlignment.Left; nl.ZIndex=14; nl.Parent=card

    local ab=Instance.new("TextButton")
    ab.Size=UDim2.new(0,86,0,28); ab.Position=UDim2.new(1,-94,0.5,-14)
    ab.BackgroundColor3=Color3.fromRGB(18,35,75); ab.Text="APPLY"
    ab.TextColor3=C.accent; ab.TextSize=11; ab.Font=Enum.Font.GothamBold
    ab.BorderSizePixel=0; ab.ZIndex=14; ab.Parent=card
    Instance.new("UICorner",ab).CornerRadius=UDim.new(0,8)
    local bs=Instance.new("UIStroke"); bs.Color=Color3.fromRGB(30,70,160); bs.Thickness=1; bs.Parent=ab

    ab.MouseButton1Click:Connect(function()
        TweenService:Create(ab,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(30,80,160)}):Play()
        task.delay(0.15,function() TweenService:Create(ab,TweenInfo.new(0.1),{BackgroundColor3=Color3.fromRGB(18,35,75)}):Play() end)
        if callback then callback(name) end
    end)
    return card
end

