-- ════════════════════════════════════════════
-- UTILITY
-- ════════════════════════════════════════════
local function lerp(a,b,t) return a+(b-a)*t end

local function randomOffset()
    if S.randomizeReach then return (math.random()*2-1)*S.randomRange end
    return 0
end

local function getDelay()
    if S.fakeLag       then return lerp(S.fakeLagMin, S.fakeLagMax, math.random()) end
    if S.randomizeDelay then return math.random()*0.05 end
    if S.humanPattern  then return math.random()*0.03+0.005 end
    return 0
end

local function isAdmin(p)
    for _,n in ipairs({"ROBLOX","builderman"}) do if p.Name==n then return true end end
    return false
end

local function logEvent(msg)
    if not S.trackStats then return end
    table.insert(S.sessionLog,1,{time=string.format("%.1fs",tick()-S.sessionStart), msg=msg})
    if #S.sessionLog>60 then table.remove(S.sessionLog) end
end

local function notify(msg, col) end -- forward-declared; defined after GUI

